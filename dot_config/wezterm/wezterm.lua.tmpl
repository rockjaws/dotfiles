local function get_nvim_theme()
	local file = io.open(theme_file, "r")
	if not file then
		return "tokyonight"
	end
	local theme = file:read("*l")
	file:close()
	return theme or "tokyonight"
end
local current_theme = get_nvim_theme()
local colors = tab_colors[current_theme] or tab_colors["tokyonight"]
